(footprint Crystal_16MHz_HC49 (layer F.Cu) (tedit 6A32201E)
  (descr "Cristal 16MHz HC-49/S — ESR 50 ohm")
  (tags "crystal xtal oscilador 16mhz hc49")
  (fp_text reference REF** (at 0 -7) (layer F.SilkS)
    (effects (font (size 1 1) (thickness 0.12)))
  )
  (fp_text value Crystal_16MHz_HC49 (at 0 7) (layer F.Fab)
    (effects (font (size 1 1) (thickness 0.1)))
  )
  (fp_line (start -2.35 -5.5) (end 2.35 -5.5) (layer F.SilkS) (width 0.12))
  (fp_line (start -2.35 5.5) (end 2.35 5.5) (layer F.SilkS) (width 0.12))
  (fp_line (start -2.35 -5.5) (end -2.35 5.5) (layer F.SilkS) (width 0.12))
  (fp_line (start 2.35 -5.5) (end 2.35 5.5) (layer F.SilkS) (width 0.12))
  (fp_line (start -2.35 -5.5) (end 2.35 -5.5) (layer F.Fab) (width 0.1))
  (fp_line (start -2.35 5.5) (end 2.35 5.5) (layer F.Fab) (width 0.1))
  (fp_line (start -2.35 -5.5) (end -2.35 5.5) (layer F.Fab) (width 0.1))
  (fp_line (start 2.35 -5.5) (end 2.35 5.5) (layer F.Fab) (width 0.1))
  (fp_line (start -3.84 -6) (end 3.84 -6) (layer F.CrtYd) (width 0.05))
  (fp_line (start -3.84 6) (end 3.84 6) (layer F.CrtYd) (width 0.05))
  (fp_line (start -3.84 -6) (end -3.84 6) (layer F.CrtYd) (width 0.05))
  (fp_line (start 3.84 -6) (end 3.84 6) (layer F.CrtYd) (width 0.05))
  (pad 1 thru_hole rect (at -2.44 0) (size 1.8 1.8) (drill 0.9) (layers *.Cu *.Mask))
  (pad 2 thru_hole circle (at 2.44 0) (size 1.8 1.8) (drill 0.9) (layers *.Cu *.Mask))
  (model ${KIPRJMOD}/saida/Crystal_16MHz_HC49.step
    (at (xyz 0 0 0))
    (scale (xyz 1 1 1))
    (rotate (xyz 0 0 0))
  )
)